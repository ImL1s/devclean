#!/bin/bash

# 1. 參數解析
DRY_RUN=false
DEEP=false
OPTIMIZE=false
DISK=false

usage() {
    echo "Usage: devclean [OPTIONS]"
    echo ""
    echo "Safely kill orphaned development processes (PPID=1) to reclaim memory."
    echo ""
    echo "Options:"
    echo "  --deep      Also kill heavy background daemons (Gradle, Kotlin LSP, iOS Simulators,"
    echo "              FVM, Antigravity Language Server, Logi Options+)"
    echo "              ⚠️  May interrupt active builds — use --dry-run first to preview"
    echo "  --optimize  Disable crash reporters in VS Code / Cursor / Windsurf / Antigravity / Kiro,"
    echo "              clean Crashpad dump files, and disable background agents (ChatGPTHelper, FigmaAgent)"
    echo "  --disk      Clean development caches and build artifacts to reclaim disk space"
    echo "              (Xcode DerivedData, Gradle, FVM, node_modules, build/, etc.)"
    echo "  --dry-run   Show what would be cleaned without actually deleting anything"
    echo "  -h, --help  Show this help message"
}

for arg in "$@"; do
    case "$arg" in
        --deep)     DEEP=true ;;
        --optimize) OPTIMIZE=true ;;
        --disk)     DISK=true ;;
        --dry-run)  DRY_RUN=true ;;
        -h|--help)  usage; exit 0 ;;
        *) echo "Unknown option: $arg"; usage; exit 1 ;;
    esac
done

echo "🔍 Scanning for orphaned development processes..."
$DRY_RUN && echo "  (dry-run mode: no processes will be killed)"

# 2. 作業系統偵測
OS="$(uname -s)"

# 3. 定義通用的孤兒進程特徵 (可輕易擴充)
# 包含常見的現代 AI 開發工具 (MCP)、前端工具與跨平台開發工具
ORPHAN_PATTERNS=(
  # AI & MCP Servers (Common)
  "mcp-server|playwright-mcp"
  # AI & MCP Servers (Personal / Custom — remove or replace with your own)
  "context7|mobile-mcp"
  # AI Language Servers (Antigravity, etc.)
  "language_server_macos|language_server_linux"
  # Node.js Wrappers (MCP related)
  "npm exec @playwright|npm exec @mobilenext|npm exec @upstash"
  # Frontend Dev Servers (webpack, vite, next.js, esbuild, turbopack)
  "webpack-dev-server|vite.*--host|next-server|next dev|esbuild.*--serve|turbopack"
  # Dart & Flutter Tooling (includes all fvm-managed processes)
  "flutter_tester|dart.*(tooling-daemon|devtools|development-service)|(^|/)fvm "
  # iOS Logging
  "log stream.*Runner"
  # Claude Code CLI 孤兒進程 (Activity Monitor 顯示為版本號如 "2.1.70")
  # 寬泛匹配所有 claude CLI 呼叫方式（安全：腳本僅殺 PPID=1 的孤兒）
  "(^| )claude( |$)"
  # Claude Code 任務監視器 (shell-snapshot + tail -f task output)
  "zsh.*shell-snapshots/snapshot-zsh.*tasks/.*\.output"
  "tail -f.*/tmp/claude-.*/tasks/.*\.output"
  # MCP Porter daemon 孤兒
  "mcporter daemon"
  # AI IDE / CLI 工具孤兒 (Kiro, Codex, Windsurf 等)
  "kiro_cli_desktop|codex.*--dangerously|windsurf"
  # Third-party app orphans (helper/agent persists after main app closes)
  "ChatGPTHelper|FigmaAgent|crashpad_handler|FirebaseCrashlytics/upload-symbols"
)

# 將陣列組合成正則表達式字串
REGEX_PATTERN=$(IFS="|"; echo "${ORPHAN_PATTERNS[*]}")

# 4. 通用函式

# 計算並回報進程統計（不執行 kill）
report_stats() {
    local PIDS="$1"
    local LABEL="$2"

    if [ -z "$PIDS" ]; then
        echo "✅ No $LABEL found."
        return 1
    fi

    # ps -o rss= 取得記憶體 (KB)，在 Linux 與 macOS 皆可運作
    local STATS
    STATS=$(ps -o rss= -p $PIDS 2>/dev/null | awk '{sum+=$1; count++} END {printf "%d|%.2f", count, sum/1024}')
    local COUNT="${STATS%%|*}"
    local MEM="${STATS##*|}"

    echo "🔪 Killing $COUNT $LABEL (Reclaiming ~$MEM MB)..."
    return 0
}

# 送出 SIGTERM，等待最多 2 秒，對未退出的進程送 SIGKILL
graceful_kill() {
    local PIDS="$1"
    [ -z "$PIDS" ] && return

    if $DRY_RUN; then
        echo "   → would kill PIDs: $PIDS"
        return
    fi

    # SIGTERM 先禮貌請求退出
    echo "$PIDS" | xargs kill -- 2>/dev/null

    # 等待最多 2 秒讓進程自行退出
    local waited=0
    while [ $waited -lt 4 ]; do
        local remaining=""
        for pid in $PIDS; do
            kill -0 "$pid" 2>/dev/null && remaining="$remaining $pid"
        done
        remaining=$(echo "$remaining" | xargs)
        [ -z "$remaining" ] && return
        sleep 0.5
        waited=$((waited + 1))
    done

    # 頑固進程用 SIGKILL 強制終結
    if [ -n "$remaining" ]; then
        echo "   ⚡ Force killing unresponsive PIDs: $remaining"
        echo "$remaining" | xargs kill -9 -- 2>/dev/null
    fi
}

# 計算統計 + 優雅終結進程
kill_and_report() {
    local PIDS="$1"
    local LABEL="$2"
    report_stats "$PIDS" "$LABEL" && graceful_kill "$PIDS"
}

# 用關鍵字搜尋並清理進程（用於深度清理）
# 使用 pgrep -f 取代 ps|grep 管線，避免自身匹配問題
cleanup_by_name() {
    local label="$1"
    local pattern="$2"
    local PIDS
    PIDS=$(pgrep -f "$pattern" 2>/dev/null | xargs)
    kill_and_report "$PIDS" "$label processes"
}

# 只清理孤兒進程 (PPID=1)，用於可能正在活躍使用的工具（如 xcodebuild）
cleanup_orphaned_by_name() {
    local label="$1"
    local pattern="$2"
    local PIDS
    PIDS=$(pgrep -P 1 -f "$pattern" 2>/dev/null | xargs)
    kill_and_report "$PIDS" "$label processes"
}

# 5. 尋找安全的孤兒進程 (PPID=1)
ORPHAN_PIDS=$(ps -eo ppid,pid,command | grep -E "$REGEX_PATTERN" | grep -v grep | awk '$1 == 1 {print $2}')
# adb logcat 也只清理孤兒 (PPID=1)，避免誤殺使用者主動開啟的 logcat
ADB_PIDS=$(ps -eo ppid,pid,command | grep -E 'adb.*logcat' | grep -v grep | awk '$1 == 1 {print $2}')

# 合併需要安全清理的 PID
PIDS_TO_KILL=""
[ -n "$ORPHAN_PIDS" ] && PIDS_TO_KILL="$ORPHAN_PIDS"
[ -n "$ADB_PIDS" ] && PIDS_TO_KILL="$PIDS_TO_KILL $ADB_PIDS"
PIDS_TO_KILL=$(echo "$PIDS_TO_KILL" | xargs)

if [ -n "$PIDS_TO_KILL" ]; then
    kill_and_report "$PIDS_TO_KILL" "orphaned/stale processes"
    echo "✅ Safe orphans cleaned."
else
    echo "✅ No safe orphans found. Clean!"
fi

# 6. 深度清理模式
if $DEEP; then
    echo ""
    echo "⚠️ Deep cleanup requested..."

    # 跨平台通用的深度清理 (Android, Java, Flutter 等)
    cleanup_by_name "Kotlin LSP" "kotlinLsp"
    cleanup_by_name "Gradle Daemon" "org.gradle.launcher.daemon"
    cleanup_by_name "Flutter Daemon" "flutter_tools.snapshot daemon"
    cleanup_by_name "FVM Processes" "(^|/)fvm "
    # xcodebuild 只殺孤兒 (PPID=1)，避免中斷正在進行的 build
    cleanup_orphaned_by_name "Orphaned xcodebuild" "xcodebuild"
    # Antigravity IDE language server（關視窗後不會自動回收，活躍視窗會自動重啟）
    cleanup_by_name "Antigravity Language Server" "language_server_macos_arm|language_server_linux"
    # Logitech Options+ 已知記憶體洩漏（launchd 會自動重啟）
    cleanup_by_name "Logi Options+ Agent" "logioptionsplus_agent"
    # Ruby/Fastlane/CocoaPods（只殺孤兒，避免中斷正在跑的 pod install）
    cleanup_orphaned_by_name "Ruby/Fastlane" "ruby.*fastlane|pod install"
    # Logitech 攝影機自動取景（由 logioptionsplus_agent 啟動，非 PPID=1）
    cleanup_by_name "LogiRightSight" "LogiRightSight"

    # macOS 專用的 iOS 模擬器清理
    if [ "$OS" == "Darwin" ] && command -v xcrun &> /dev/null; then
        SIM_PIDS=$(pgrep -f 'CoreSimulator|Simulator.app' 2>/dev/null | xargs)
        if report_stats "$SIM_PIDS" "iOS Simulator processes"; then
            if ! $DRY_RUN; then
                xcrun simctl shutdown all 2>/dev/null
            else
                echo "   → would run: xcrun simctl shutdown all"
            fi
        fi
    fi

    echo "✅ Deep cleanup completed."
fi

# 7. 優化模式
if $OPTIMIZE; then
    echo ""
    echo "🔧 Optimize mode requested..."

    # 7a. 停用 VS Code 系列 IDE 的 crash reporter（避免 crashpad crash loop 吃 CPU）
    ARGV_DIRS=(
        "$HOME/.vscode"
        "$HOME/.cursor"
        "$HOME/.windsurf"
        "$HOME/.antigravity"
        "$HOME/.kiro"
        "$HOME/.vscode-oss"
    )
    for dir in "${ARGV_DIRS[@]}"; do
        argv="$dir/argv.json"
        if [ -f "$argv" ] && grep -q '"enable-crash-reporter": true' "$argv"; then
            label=$(basename "$dir" | sed 's/^\.//')
            if $DRY_RUN; then
                echo "   → would patch $argv (disable crash reporter)"
            else
                sed -i.bak 's/"enable-crash-reporter": true/"enable-crash-reporter": false/' "$argv"
                rm -f "$argv.bak"
                echo "✅ Disabled crash reporter in $label ($argv)"
            fi
        fi
    done

    # 7b. 清理 Crashpad dump 檔案
    CRASHPAD_CLEANED=0
    if [ "$OS" == "Darwin" ]; then
        for crashdir in "$HOME/Library/Application Support"/*/Crashpad/pending "$HOME/Library/Application Support"/*/Crashpad/completed; do
            if [ -d "$crashdir" ]; then
                count=$(find "$crashdir" -type f 2>/dev/null | wc -l | tr -d ' ')
                if [ "$count" -gt 0 ]; then
                    CRASHPAD_CLEANED=$((CRASHPAD_CLEANED + count))
                    if ! $DRY_RUN; then
                        find "$crashdir" -mindepth 1 -delete 2>/dev/null
                    fi
                fi
            fi
        done
        # 清理 DiagnosticReports 中的 crashpad crash reports
        DIAG_COUNT=$(find "$HOME/Library/Logs/DiagnosticReports" -name "chrome_crashpad_handler*.ips" 2>/dev/null | wc -l | tr -d ' ')
        if [ "$DIAG_COUNT" -gt 0 ]; then
            CRASHPAD_CLEANED=$((CRASHPAD_CLEANED + DIAG_COUNT))
            if ! $DRY_RUN; then
                rm -f "$HOME/Library/Logs/DiagnosticReports"/chrome_crashpad_handler*.ips 2>/dev/null
            fi
        fi
    fi
    if [ "$CRASHPAD_CLEANED" -gt 0 ]; then
        if $DRY_RUN; then
            echo "   → would delete $CRASHPAD_CLEANED Crashpad dump files"
        else
            echo "✅ Cleaned $CRASHPAD_CLEANED Crashpad dump files."
        fi
    else
        echo "✅ No Crashpad dumps to clean."
    fi

    # 7c. 停用已知的 SMAppService 背景常駐（ChatGPTHelper, FigmaAgent）
    SMAPP_AGENTS=(
        "com.openai.chat-helper:ChatGPTHelper"
        "com.figma.agent:FigmaAgent"
    )
    for entry in "${SMAPP_AGENTS[@]}"; do
        label="${entry%%:*}"
        name="${entry##*:}"
        if launchctl print "gui/$(id -u)/$label" &>/dev/null; then
            if $DRY_RUN; then
                echo "   → would disable $name ($label)"
            else
                launchctl disable "gui/$(id -u)/$label" 2>/dev/null
                launchctl bootout "gui/$(id -u)/$label" 2>/dev/null
                echo "✅ Disabled $name background agent ($label)"
            fi
        fi
    done

    echo "✅ Optimization completed."
fi

# 8. 磁碟清理模式
if $DISK; then
    echo ""
    echo "💾 Disk cleanup requested..."
    DISK_TOTAL=0

    # 清理單一目錄的 helper
    clean_dir() {
        local label="$1"
        local target="$2"
        [ -d "$target" ] || return
        # 防止 symlink 攻擊（TOCTOU 防護）
        [ -L "$target" ] && return
        local size_kb
        size_kb=$(du -sk "$target" 2>/dev/null | awk '{print $1}')
        [ -z "$size_kb" ] || [ "$size_kb" -lt 1024 ] && return  # 忽略 < 1MB
        local size_mb=$((size_kb / 1024))
        DISK_TOTAL=$((DISK_TOTAL + size_mb))
        if $DRY_RUN; then
            echo "   → would clean $label (${size_mb} MB)"
        else
            rm -rf "$target"
            echo "🗑️  Cleaned $label (${size_mb} MB)"
        fi
    }

    # 清理 find 搜尋結果的 helper（帶 parent 檔案驗證）
    clean_find() {
        local label="$1"
        local scan_dir="$2"
        local dir_name="$3"
        shift 3
        local parent_files=("$@")
        local found_size=0
        local found_count=0

        while IFS= read -r d; do
            [ -z "$d" ] && continue
            local parent_dir
            parent_dir="$(dirname "$d")"
            local valid=false
            if [ ${#parent_files[@]} -eq 0 ]; then
                valid=true
            else
                for pf in "${parent_files[@]}"; do
                    [ -f "$parent_dir/$pf" ] && valid=true && break
                done
            fi
            if $valid; then
                local kb
                kb=$(du -sk "$d" 2>/dev/null | awk '{print $1}')
                [ -z "$kb" ] && continue
                found_size=$((found_size + kb))
                found_count=$((found_count + 1))
                $DRY_RUN || rm -rf "$d"
            fi
        done < <(find "$scan_dir" -maxdepth 6 -type d -name "$dir_name" 2>/dev/null)

        if [ "$found_count" -gt 0 ]; then
            local mb=$((found_size / 1024))
            DISK_TOTAL=$((DISK_TOTAL + mb))
            if $DRY_RUN; then
                echo "   → would clean $found_count $label dirs (${mb} MB)"
            else
                echo "🗑️  Cleaned $found_count $label dirs (${mb} MB)"
            fi
        fi
    }

    # === macOS 開發工具快取 ===
    if [ "$OS" == "Darwin" ]; then
        clean_dir "Xcode DerivedData" "$HOME/Library/Developer/Xcode/DerivedData"
        clean_dir "iOS DeviceSupport" "$HOME/Library/Developer/Xcode/iOS DeviceSupport"
        clean_dir "XCTestDevices" "$HOME/Library/Developer/XCTestDevices"
        clean_dir "CocoaPods cache" "$HOME/Library/Caches/CocoaPods"
        clean_dir "Playwright cache" "$HOME/Library/Caches/ms-playwright"
    fi

    # === 跨平台開發工具快取 ===
    clean_dir "Gradle caches" "$HOME/.gradle/caches"
    clean_dir "Gradle wrapper" "$HOME/.gradle/wrapper"
    clean_dir "CocoaPods repos" "$HOME/.cocoapods/repos"
    clean_dir "Pub cache" "$HOME/.pub-cache"
    clean_dir "npm cache" "$HOME/.npm"

    # === AI 工具 / IDE 快取 ===
    clean_dir "Gemini browser recordings" "$HOME/.gemini/antigravity/browser_recordings"
    clean_dir "Codex sessions" "$HOME/.codex/sessions"
    clean_dir "Codex logs" "$HOME/.codex/log"

    # === FVM 不完整版本（"Need setup" 狀態）===
    if command -v fvm &>/dev/null; then
        for ver_dir in "$HOME"/fvm/versions/*/; do
            [ -d "$ver_dir" ] || continue
            # 沒有 bin/flutter 表示下載不完整
            if [ ! -f "$ver_dir/bin/flutter" ]; then
                ver_name=$(basename "$ver_dir")
                clean_dir "FVM incomplete ($ver_name)" "$ver_dir"
            fi
        done
    fi

    # === 專案 build artifacts（~/Documents 下）===
    if [ -d "$HOME/Documents" ]; then
        clean_find "project build/" "$HOME/Documents" "build" \
            "pubspec.yaml" "build.gradle" "build.gradle.kts" "Makefile" "CMakeLists.txt"
        clean_find "project .dart_tool/" "$HOME/Documents" ".dart_tool" "pubspec.yaml"
        clean_find "project .gradle/" "$HOME/Documents" ".gradle" "build.gradle" "build.gradle.kts" "settings.gradle"
        clean_find "project node_modules/" "$HOME/Documents" "node_modules" "package.json"
    fi

    echo ""
    if [ "$DISK_TOTAL" -gt 0 ]; then
        gb=$(awk -v total="$DISK_TOTAL" 'BEGIN {printf "%.1f", total / 1024}')
        if $DRY_RUN; then
            echo "📊 Total reclaimable: ${DISK_TOTAL} MB (~${gb} GB)"
        else
            echo "📊 Total reclaimed: ${DISK_TOTAL} MB (~${gb} GB)"
        fi
    else
        echo "✅ No significant disk caches to clean."
    fi
    echo "✅ Disk cleanup completed."
fi

if ! $DEEP && ! $OPTIMIZE && ! $DISK; then
    echo ""
    echo "💡 Tip: Run 'devclean --deep' for heavy daemons, 'devclean --optimize' for IDE settings, or 'devclean --disk' for disk space."
fi
